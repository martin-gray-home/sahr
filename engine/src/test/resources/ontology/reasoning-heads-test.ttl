@prefix headr: <https://sahr.ai/ontology/reasoning#> .
@prefix test: <http://example.org/test#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

headr:ReasoningHead a owl:Class .
headr:Pattern a owl:Class .
headr:TriplePattern a owl:Class .
headr:Variable a owl:Class .
headr:Constant a owl:Class .
headr:AddAssertion a owl:Class .
headr:ScorePolicy a owl:Class .
headr:ExecutorParam a owl:Class .

headr:hasPattern a owl:ObjectProperty .
headr:hasTriple a owl:ObjectProperty .
headr:hasAction a owl:ObjectProperty .
headr:hasScorePolicy a owl:ObjectProperty .
headr:hasExecutorParam a owl:ObjectProperty .
headr:subject a owl:ObjectProperty .
headr:predicate a owl:ObjectProperty .
headr:object a owl:ObjectProperty .

headr:name a owl:DatatypeProperty .
headr:varName a owl:DatatypeProperty .
headr:value a owl:DatatypeProperty .
headr:baseWeight a owl:DatatypeProperty .
headr:executorType a owl:DatatypeProperty .
headr:paramKey a owl:DatatypeProperty .
headr:paramValue a owl:DatatypeProperty .

headr:varX a headr:Variable ;
    headr:varName "x" .

headr:varY a headr:Variable ;
    headr:varName "y" .

headr:varZ a headr:Variable ;
    headr:varName "z" .

headr:constLocatedIn a headr:Constant ;
    headr:value "http://example.org/test#locatedIn" .

headr:tpLeft a headr:TriplePattern ;
    headr:subject headr:varX ;
    headr:predicate headr:constLocatedIn ;
    headr:object headr:varY .

headr:tpRight a headr:TriplePattern ;
    headr:subject headr:varY ;
    headr:predicate headr:constLocatedIn ;
    headr:object headr:varZ .

headr:patternTransitive a headr:Pattern ;
    headr:hasTriple headr:tpLeft, headr:tpRight .

headr:actionTransitive a headr:AddAssertion ;
    headr:subject headr:varX ;
    headr:predicate headr:constLocatedIn ;
    headr:object headr:varZ .

headr:scoreTransitive a headr:ScorePolicy ;
    headr:baseWeight "0.8"^^xsd:double .

headr:TransitiveLocatedInHead a headr:ReasoningHead ;
    headr:name "transitive-test" ;
    headr:hasPattern headr:patternTransitive ;
    headr:hasAction headr:actionTransitive ;
    headr:hasScorePolicy headr:scoreTransitive .

headr:scoreRuleForwardChain a headr:ScorePolicy ;
    headr:baseWeight "0.6"^^xsd:double .

headr:RuleForwardChainHead a headr:ReasoningHead ;
    headr:name "rule-forward-chain-test" ;
    headr:executorType "RULE_FORWARD_CHAIN" ;
    headr:hasScorePolicy headr:scoreRuleForwardChain .
