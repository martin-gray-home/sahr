<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/test#"
     xml:base="http://example.org/test"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.org/test"/>

    <owl:Class rdf:about="http://example.org/test#Doctor">
        <rdfs:label>doctor</rdfs:label>
    </owl:Class>

    <owl:ObjectProperty rdf:about="http://example.org/test#relatedTo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/test#contains">
        <owl:inverseOf rdf:resource="http://example.org/test#inside"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/test#inside"/>

    <owl:ObjectProperty rdf:about="http://example.org/test#locatedIn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
</rdf:RDF>
