@prefix sahr: <https://sahr.ai/ontology/relations#> .
@prefix head: <https://sahr.ai/ontology/head#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://sahr.ai/ontology/relations>
    a owl:Ontology ;
    rdfs:label "SAHR Relations" .

sahr:on a owl:ObjectProperty ;
    rdfs:label "on" ;
    rdfs:subPropertyOf sahr:surfaceContact .

sahr:colocation a owl:ObjectProperty ;
    rdfs:label "co-location" ;
    rdfs:subPropertyOf head:colocation .

sahr:locationTransferRelation a owl:ObjectProperty ;
    rdfs:label "location transfer relation" .

sahr:surfaceContact a owl:ObjectProperty ;
    rdfs:label "surface contact" ;
    rdfs:subPropertyOf head:surfaceContact .

sahr:containment a owl:ObjectProperty ;
    rdfs:label "containment" ;
    rdfs:subPropertyOf head:containment .

sahr:proximity a owl:ObjectProperty ;
    rdfs:label "proximity" ;
    rdfs:subPropertyOf sahr:locationTransferRelation .

sahr:near a owl:ObjectProperty ;
    rdfs:label "near" ;
    rdfs:subPropertyOf sahr:colocation ;
    rdfs:subPropertyOf sahr:proximity .

sahr:beside a owl:ObjectProperty ;
    rdfs:label "beside" ;
    rdfs:subPropertyOf sahr:colocation ;
    rdfs:subPropertyOf sahr:proximity .

sahr:alongside a owl:ObjectProperty ;
    rdfs:label "alongside" ;
    rdfs:subPropertyOf sahr:colocation ;
    rdfs:subPropertyOf sahr:proximity .

sahr:nextTo a owl:ObjectProperty ;
    rdfs:label "next to" ;
    rdfs:subPropertyOf sahr:colocation ;
    rdfs:subPropertyOf sahr:proximity .

sahr:locatedIn a owl:ObjectProperty ;
    rdfs:label "locatedIn" ;
    rdfs:label "located in" ;
    rdfs:subPropertyOf sahr:containment .

sahr:inside a owl:ObjectProperty ;
    rdfs:label "inside" ;
    rdfs:subPropertyOf sahr:containment .

sahr:in a owl:ObjectProperty ;
    rdfs:label "in" ;
    rdfs:subPropertyOf sahr:containment .

sahr:at a owl:ObjectProperty ;
    rdfs:label "at" ;
    rdfs:subPropertyOf sahr:locationTransferRelation ;
    rdfs:subPropertyOf head:locationTransfer .

sahr:above a owl:ObjectProperty ;
    rdfs:label "above" ;
    rdfs:subPropertyOf sahr:proximity .

sahr:below a owl:ObjectProperty ;
    rdfs:label "below" ;
    owl:inverseOf sahr:above .

sahr:under a owl:ObjectProperty ;
    rdfs:label "under" ;
    owl:inverseOf sahr:on ;
    rdfs:subPropertyOf sahr:surfaceContact .

sahr:opposite a owl:ObjectProperty ;
    rdfs:label "opposite" ;
    a owl:SymmetricProperty ;
    rdfs:subPropertyOf sahr:colocation .

sahr:partOf a owl:ObjectProperty ;
    rdfs:label "partOf" ;
    rdfs:label "part of" ;
    rdfs:subPropertyOf sahr:colocation .

sahr:hold a owl:ObjectProperty ;
    rdfs:label "hold" ;
    rdfs:subPropertyOf sahr:colocation .

sahr:carry a owl:ObjectProperty ;
    rdfs:label "carry" ;
    rdfs:subPropertyOf sahr:colocation .

sahr:possess a owl:ObjectProperty ;
    rdfs:label "possess" ;
    rdfs:subPropertyOf sahr:colocation .

sahr:have a owl:ObjectProperty ;
    rdfs:label "have" ;
    rdfs:subPropertyOf sahr:colocation .

sahr:wear a owl:ObjectProperty ;
    rdfs:label "wear" ;
    rdfs:subPropertyOf sahr:on ;
    rdfs:subPropertyOf sahr:colocation .

sahr:wornBy a owl:ObjectProperty ;
    rdfs:label "worn by" ;
    owl:inverseOf sahr:wear ;
    rdfs:subPropertyOf sahr:on .

sahr:with a owl:ObjectProperty ;
    rdfs:label "with" ;
    a owl:SymmetricProperty ;
    rdfs:subPropertyOf sahr:colocation ;
    rdfs:subPropertyOf sahr:proximity .

sahr:hasAttribute a owl:ObjectProperty ;
    rdfs:label "hasAttribute" ;
    rdfs:subPropertyOf head:attributeRelation .

sahr:poweredBy a owl:ObjectProperty ;
    rdfs:label "poweredBy" ;
    rdfs:label "powered by" ;
    rdfs:label "power" ;
    rdfs:label "require" ;
    rdfs:label "requires" ;
    rdfs:label "required" ;
    rdfs:label "needs" ;
    rdfs:subPropertyOf head:dependencyChain .

sahr:chargedBy a owl:ObjectProperty ;
    rdfs:label "chargedBy" ;
    rdfs:label "charged by" ;
    rdfs:subPropertyOf head:dependencyChain .

sahr:fail a owl:ObjectProperty ;
    rdfs:label "fail" ;
    rdfs:label "fails" ;
    rdfs:label "failed" ;
    rdfs:label "failure" ;
    rdfs:label "stop responding" ;
    rdfs:label "stop_responding" ;
    rdfs:label "stop functioning" ;
    rdfs:label "stop_functioning" ;
    rdfs:label "cannot operate" ;
    rdfs:label "cannot function" ;
    rdfs:subPropertyOf head:dependencyChain .

sahr:causalRelation a owl:ObjectProperty ;
    rdfs:label "causal relation" ;
    rdfs:subPropertyOf head:causalRelation .

sahr:cause a owl:ObjectProperty ;
    rdfs:label "cause" ;
    rdfs:label "causes" ;
    rdfs:label "can cause" ;
    rdfs:label "may cause" ;
    rdfs:label "lead to" ;
    rdfs:label "result in" ;
    a owl:TransitiveProperty ;
    owl:inverseOf sahr:causedBy ;
    rdfs:subPropertyOf sahr:causalRelation .

sahr:causedBy a owl:ObjectProperty ;
    rdfs:label "caused by" ;
    owl:inverseOf sahr:cause ;
    rdfs:subPropertyOf sahr:causalRelation .

sahr:temporalRelation a owl:ObjectProperty ;
    rdfs:label "temporal relation" ;
    rdfs:subPropertyOf head:temporalRelation .

sahr:before a owl:ObjectProperty ;
    rdfs:label "before" ;
    rdfs:label "prior to" ;
    rdfs:label "earlier than" ;
    a owl:TransitiveProperty ;
    owl:inverseOf sahr:after ;
    rdfs:subPropertyOf sahr:temporalRelation .

sahr:after a owl:ObjectProperty ;
    rdfs:label "after" ;
    rdfs:label "following" ;
    a owl:TransitiveProperty ;
    rdfs:subPropertyOf sahr:temporalRelation .

sahr:during a owl:ObjectProperty ;
    rdfs:label "during" ;
    rdfs:label "while" ;
    rdfs:label "within" ;
    rdfs:subPropertyOf sahr:temporalRelation .
