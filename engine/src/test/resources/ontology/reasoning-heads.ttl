@prefix headr: <https://sahr.ai/ontology/reasoning#> .
@prefix sahr: <https://sahr.ai/ontology/relations#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

headr:ReasoningHead a owl:Class .
headr:Pattern a owl:Class .
headr:TriplePattern a owl:Class .
headr:Variable a owl:Class .
headr:Constant a owl:Class .
headr:AddAssertion a owl:Class .
headr:ScorePolicy a owl:Class .
headr:ExecutorParam a owl:Class .

headr:hasPattern a owl:ObjectProperty .
headr:hasTriple a owl:ObjectProperty .
headr:hasAction a owl:ObjectProperty .
headr:hasScorePolicy a owl:ObjectProperty .
headr:hasExecutorParam a owl:ObjectProperty .
headr:subject a owl:ObjectProperty .
headr:predicate a owl:ObjectProperty .
headr:object a owl:ObjectProperty .

headr:name a owl:DatatypeProperty .
headr:varName a owl:DatatypeProperty .
headr:value a owl:DatatypeProperty .
headr:baseWeight a owl:DatatypeProperty .
headr:executorType a owl:DatatypeProperty .
headr:paramKey a owl:DatatypeProperty .
headr:paramValue a owl:DatatypeProperty .

headr:varA a headr:Variable ;
    headr:varName "a" .

headr:varB a headr:Variable ;
    headr:varName "b" .

headr:varC a headr:Variable ;
    headr:varName "c" .

headr:constIn a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#in" .

headr:constInside a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#inside" .

headr:constLocatedIn a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#locatedIn" .

headr:constOn a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#on" .

headr:constUnder a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#under" .

headr:constWith a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#with" .

headr:constWear a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#wear" .

headr:constWornBy a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#wornBy" .

headr:constHold a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#hold" .

headr:constCarry a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#carry" .

headr:constPossess a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#possess" .

headr:constHave a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#have" .

headr:constOpposite a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#opposite" .

headr:constPartOf a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#partOf" .

headr:constColocation a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#colocation" .

headr:constNear a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#near" .

headr:constBeside a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#beside" .

headr:constAlongside a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#alongside" .

headr:constNextTo a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#nextTo" .

headr:constPoweredBy a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#poweredBy" .

headr:constChargedBy a headr:Constant ;
    headr:value "https://sahr.ai/ontology/relations#chargedBy" .

headr:scoreContainment a headr:ScorePolicy ;
    headr:baseWeight "0.72"^^xsd:double .

headr:scoreColocation a headr:ScorePolicy ;
    headr:baseWeight "0.7"^^xsd:double .

headr:scoreSurface a headr:ScorePolicy ;
    headr:baseWeight "0.68"^^xsd:double .

headr:scoreDependency a headr:ScorePolicy ;
    headr:baseWeight "0.74"^^xsd:double .

headr:scoreAssertionInsertion a headr:ScorePolicy ;
    headr:baseWeight "1.0"^^xsd:double .

headr:scoreRelationQuery a headr:ScorePolicy ;
    headr:baseWeight "1.0"^^xsd:double .

headr:scoreGraphRetrieval a headr:ScorePolicy ;
    headr:baseWeight "1.0"^^xsd:double .

headr:scoreQueryAlignment a headr:ScorePolicy ;
    headr:baseWeight "1.0"^^xsd:double .

headr:scoreSubgoalExpansion a headr:ScorePolicy ;
    headr:baseWeight "1.0"^^xsd:double .

headr:paramGraphRetrievalDepth a headr:ExecutorParam ;
    headr:paramKey "maxLocationDepth" ;
    headr:paramValue "6" .

headr:AssertionInsertionHead a headr:ReasoningHead ;
    headr:name "assertion-insertion" ;
    headr:executorType "ASSERTION_INSERTION" ;
    headr:hasScorePolicy headr:scoreAssertionInsertion .

headr:RelationQueryHead a headr:ReasoningHead ;
    headr:name "relation-query" ;
    headr:executorType "RELATION_QUERY" ;
    headr:hasScorePolicy headr:scoreRelationQuery .

headr:GraphRetrievalHead a headr:ReasoningHead ;
    headr:name "graph-retrieval" ;
    headr:executorType "GRAPH_RETRIEVAL" ;
    headr:hasExecutorParam headr:paramGraphRetrievalDepth ;
    headr:hasScorePolicy headr:scoreGraphRetrieval .

headr:QueryAlignmentHead a headr:ReasoningHead ;
    headr:name "query-alignment" ;
    headr:executorType "QUERY_ALIGNMENT" ;
    headr:hasScorePolicy headr:scoreQueryAlignment .

headr:SubgoalExpansionHead a headr:ReasoningHead ;
    headr:name "subgoal-expansion" ;
    headr:executorType "SUBGOAL_EXPANSION" ;
    headr:hasScorePolicy headr:scoreSubgoalExpansion .

headr:tpInLeft a headr:TriplePattern ;
    headr:subject headr:varA ;
    headr:predicate headr:constIn ;
    headr:object headr:varB .

headr:tpInRight a headr:TriplePattern ;
    headr:subject headr:varB ;
    headr:predicate headr:constIn ;
    headr:object headr:varC .

headr:patternInTransitive a headr:Pattern ;
    headr:hasTriple headr:tpInLeft, headr:tpInRight .

headr:actionInTransitive a headr:AddAssertion ;
    headr:subject headr:varA ;
    headr:predicate headr:constIn ;
    headr:object headr:varC .

headr:TransitiveInHead a headr:ReasoningHead ;
    headr:name "transitive-in" ;
    headr:hasPattern headr:patternInTransitive ;
    headr:hasAction headr:actionInTransitive ;
    headr:hasScorePolicy headr:scoreContainment .

headr:tpInsideLeft a headr:TriplePattern ;
    headr:subject headr:varA ;
    headr:predicate headr:constInside ;
    headr:object headr:varB .

headr:tpInsideRight a headr:TriplePattern ;
