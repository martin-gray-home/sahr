@prefix sahr: <https://sahr.ai/ontology/relations#> .
@prefix ann: <https://sahr.ai/ontology/annotations#> .
@prefix sc: <https://sahr.ai/ontology/spacecraft#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://sahr.ai/ontology/spacecraft>
    a owl:Ontology ;
    rdfs:label "SAHR Spacecraft Domain" .

ann:answerTemplate a owl:AnnotationProperty .
ann:answerTemplateTrue a owl:AnnotationProperty .
ann:answerTemplateFalse a owl:AnnotationProperty .
ann:dynamicWeight a owl:AnnotationProperty .
ann:temporalWeight a owl:AnnotationProperty .
ann:evidenceWeight a owl:AnnotationProperty .
ann:semanticRole a owl:AnnotationProperty .

sc:ControlSpacecraftOrientation a owl:Class ;
    rdfs:label "spacecraft orientation control" ;
    skos:altLabel "control spacecraft orientation" ;
    skos:altLabel "spacecraft orientation" ;
    ann:semanticRole "control_target" .

sc:RecoveryPeriod a owl:NamedIndividual ;
    rdfs:label "recovery period" ;
    skos:altLabel "recovery" ;
    ann:semanticRole "recovery_phase" .

sc:Telemetry a owl:NamedIndividual ;
    rdfs:label "telemetry" ;
    ann:semanticRole "evidence_signal" .

sc:TemperatureSpikes a owl:NamedIndividual ;
    rdfs:label "temperature spikes" ;
    skos:altLabel "temperature spike" ;
    ann:semanticRole "evidence_signal" .

sc:ElectricallyPoweredActuators a owl:NamedIndividual ;
    rdfs:label "electrically powered actuators" ;
    skos:altLabel "electrical actuators" .

sahr:fail ann:dynamicWeight "0.55"^^xsd:decimal ;
    ann:answerTemplateTrue "verb:fail" ;
    ann:answerTemplateFalse "verb:fail;negated:true" .

sahr:restore ann:dynamicWeight "0.55"^^xsd:decimal ;
    ann:answerTemplate "verb:restore" .

sahr:backupFor ann:dynamicWeight "0.55"^^xsd:decimal ;
    ann:answerTemplate "verb:be;object:backup;prep:for" .

sahr:poweredBy ann:dynamicWeight "-0.25"^^xsd:decimal ;
    ann:answerTemplate "verb:power;voice:passive;prep:by" .

sahr:cause ann:dynamicWeight "0.55"^^xsd:decimal ;
    ann:answerTemplate "verb:cause" .

sahr:causedBy ann:dynamicWeight "0.55"^^xsd:decimal ;
    ann:answerTemplate "verb:cause;voice:passive;prep:by" .

sahr:before ann:temporalWeight "0.20"^^xsd:decimal .
sahr:after ann:temporalWeight "0.40"^^xsd:decimal .
sahr:during ann:temporalWeight "0.20"^^xsd:decimal .

sahr:indicate ann:evidenceWeight "0.35"^^xsd:decimal .
